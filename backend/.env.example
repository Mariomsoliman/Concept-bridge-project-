# Backend environment variables

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# PubMed (no key needed, but can be configured for higher limits)
PUBMED_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
PUBMED_EMAIL=your_email@example.com

# Stack Exchange
STACK_EXCHANGE_API_KEY=your_stack_exchange_api_key_here
STACK_EXCHANGE_SITE=stackoverflow

# arXiv (no key needed)
ARXIV_BASE_URL=http://export.arxiv.org/api/query

# Crossref (no key needed)
CROSSREF_BASE_URL=https://api.crossref.org/v1

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:8015
